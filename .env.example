]633;E;echo "# CascadeX Environment Variables";cc6fa943-98eb-4336-83eb-ae04b978d56c]633;C# CascadeX Environment Variables
# Copy this to .env and fill in your values

# Django Core
DEBUG=False
SECRET_KEY=generate_a_long_random_string_here
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database (Local Development)
DB_NAME=cascadex_db
DB_USER=cascadex_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5433

# Database (Production - Railway provides this)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Frontend URL (CORS)
FRONTEND_URL=https://your-app.vercel.app

# NVD API
NVD_API_KEY=your_nvd_api_key_here

# JWT
JWT_ACCESS_TOKEN_LIFETIME_HOURS=12
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Redirects
OAUTH_CALLBACK_SUCCESS_URL=https://your-app.vercel.app/dashboard
OAUTH_CALLBACK_FAILURE_URL=https://your-app.vercel.app/login?error=oauth_failed

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@cascadex.com

# Production Security
SECURE_SSL_REDIRECT=True
